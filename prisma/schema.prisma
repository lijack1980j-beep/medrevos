generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CalendarEventType {
  EVENT
  EXAM
  NOTE
}

enum QuestionType {
  SINGLE_BEST
  MULTI_SELECT
  TRUE_FALSE
}

enum ExamStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id             String              @id @default(cuid())
  name           String
  email          String              @unique
  passwordHash   String
  role           UserRole            @default(STUDENT)
  examDate       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sessions       Session[]
  attempts       QuestionAttempt[]
  progress       UserTopicProgress[]
  reviews        FlashcardReview[]
  flashcardState UserFlashcardState[]
  bookmarks      Bookmark[]
  notes          TopicNote[]
  examSessions   ExamSession[]
  questionSRS      QuestionSRSState[]
  customCards      Flashcard[]         @relation("CustomFlashcards")
  calendarEvents   CalendarEvent[]
  blockedSections  String[]            @default([])
  ownedTopics      Topic[]             @relation("UserOwnedTopics")
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Topic {
  id               String              @id @default(cuid())
  slug             String              @unique
  title            String
  system           String
  summary          String
  difficulty       Int
  estMinutes       Int
  highYield        Boolean             @default(false)
  assignedToUserId String?
  assignedTo       User?               @relation("UserOwnedTopics", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  lessons          Lesson[]
  questions        Question[]
  flashcards       Flashcard[]
  cases            CaseStudy[]
  progress         UserTopicProgress[]
  notes            TopicNote[]
}

model Lesson {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  content     String
  pearls      String
  pitfalls    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Question {
  id              String        @id @default(cuid())
  topicId         String
  stem            String
  explanation     String
  difficulty      Int
  type            QuestionType  @default(SINGLE_BEST)
  correctOptionId String?
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  topic           Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  options         QuestionOption[]
  attempts        QuestionAttempt[]
  bookmarks       Bookmark[]
  examAnswers     ExamAnswer[]
  srsStates       QuestionSRSState[]
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  label       String
  text        String
  isCorrect   Boolean  @default(false)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id              String        @id @default(cuid())
  topicId         String
  front           String
  back            String
  note            String?
  intervalDays    Int           @default(0)
  easeFactor      Float         @default(2.5)
  repetitions     Int           @default(0)
  dueDate         DateTime      @default(now())
  isCustom        Boolean       @default(false)
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  topic           Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author          User?         @relation("CustomFlashcards", fields: [authorId], references: [id], onDelete: SetNull)
  reviewHistory   FlashcardReview[]
  userStates      UserFlashcardState[]
}

model FlashcardReview {
  id           String       @id @default(cuid())
  flashcardId  String
  userId       String
  rating       ReviewRating
  reviewedAt   DateTime     @default(now())
  nextDueDate  DateTime
  flashcard    Flashcard    @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionAttempt {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  selected    String
  isCorrect   Boolean
  createdAt   DateTime @default(now())
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionSRSState {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  intervalDays Int      @default(1)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)
  dueDate      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model UserFlashcardState {
  id           String   @id @default(cuid())
  userId       String
  flashcardId  String
  intervalDays Int      @default(0)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)
  dueDate      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model UserTopicProgress {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  masteryPercent Int      @default(0)
  questionCount  Int      @default(0)
  correctCount   Int      @default(0)
  lastStudiedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model CaseStudy {
  id             String   @id @default(cuid())
  topicId        String
  title          String
  chiefComplaint String
  findings       String
  investigations String
  diagnosis      String
  management     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId])
}

model TopicNote {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@unique([userId, topicId])
}

model ExamSession {
  id           String     @id @default(cuid())
  userId       String
  status       ExamStatus @default(IN_PROGRESS)
  timeLimitSec Int
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      ExamAnswer[]
}

model CalendarEvent {
  id        String            @id @default(cuid())
  userId    String
  type      CalendarEventType
  title     String
  dateStr   String            // 'YYYY-MM-DD'
  note      String?
  color     String?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamAnswer {
  id         String      @id @default(cuid())
  sessionId  String
  questionId String
  selected   String?
  isCorrect  Boolean?
  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([sessionId, questionId])
}
