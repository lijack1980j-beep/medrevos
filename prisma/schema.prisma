generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum QuestionType {
  SINGLE_BEST
  MULTI_SELECT
  TRUE_FALSE
}

enum ExamStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id             String              @id @default(cuid())
  name           String
  email          String              @unique
  passwordHash   String
  role           UserRole            @default(STUDENT)
  examDate       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sessions       Session[]
  attempts       QuestionAttempt[]
  progress       UserTopicProgress[]
  reviews        FlashcardReview[]
  flashcardState UserFlashcardState[]
  bookmarks      Bookmark[]
  notes          TopicNote[]
  examSessions   ExamSession[]
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Topic {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  system      String
  summary     String
  difficulty  Int
  estMinutes  Int
  highYield   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lessons     Lesson[]
  questions   Question[]
  flashcards  Flashcard[]
  cases       CaseStudy[]
  progress    UserTopicProgress[]
  notes       TopicNote[]
}

model Lesson {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  content     String
  pearls      String
  pitfalls    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Question {
  id              String        @id @default(cuid())
  topicId         String
  stem            String
  explanation     String
  difficulty      Int
  type            QuestionType  @default(SINGLE_BEST)
  correctOptionId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  topic           Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  options         QuestionOption[]
  attempts        QuestionAttempt[]
  bookmarks       Bookmark[]
  examAnswers     ExamAnswer[]
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  label       String
  text        String
  isCorrect   Boolean  @default(false)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id              String        @id @default(cuid())
  topicId         String
  front           String
  back            String
  note            String?
  intervalDays    Int           @default(0)
  easeFactor      Float         @default(2.5)
  repetitions     Int           @default(0)
  dueDate         DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  topic           Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reviewHistory   FlashcardReview[]
  userStates      UserFlashcardState[]
}

model FlashcardReview {
  id           String       @id @default(cuid())
  flashcardId  String
  userId       String
  rating       ReviewRating
  reviewedAt   DateTime     @default(now())
  nextDueDate  DateTime
  flashcard    Flashcard    @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionAttempt {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  selected    String
  isCorrect   Boolean
  createdAt   DateTime @default(now())
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model UserFlashcardState {
  id           String   @id @default(cuid())
  userId       String
  flashcardId  String
  intervalDays Int      @default(0)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)
  dueDate      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model UserTopicProgress {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  masteryPercent Int      @default(0)
  questionCount  Int      @default(0)
  correctCount   Int      @default(0)
  lastStudiedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model CaseStudy {
  id             String   @id @default(cuid())
  topicId        String
  title          String
  chiefComplaint String
  findings       String
  investigations String
  diagnosis      String
  management     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId])
}

model TopicNote {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@unique([userId, topicId])
}

model ExamSession {
  id           String     @id @default(cuid())
  userId       String
  status       ExamStatus @default(IN_PROGRESS)
  timeLimitSec Int
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      ExamAnswer[]
}

model ExamAnswer {
  id         String      @id @default(cuid())
  sessionId  String
  questionId String
  selected   String?
  isCorrect  Boolean?
  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([sessionId, questionId])
}
